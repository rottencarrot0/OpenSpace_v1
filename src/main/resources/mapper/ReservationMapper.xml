<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!--        id, space_id, guest_id, start_date, end_date, total_price, status, created_at, updated_at, is_deleted-->
<mapper namespace="openspace.page.mapper.ReservationMapper">

    <insert id="insertReservation" parameterType="Reservation" useGeneratedKeys="true" keyProperty="id">
        insert into reservation (space_id, guest_id, start_date, end_date, total_price, status)
        values (#{spaceId}, #{guestId}, #{startDate}, #{endDate}, #{totalPrice}, #{status})
    </insert>
</mapper>